# Copy to `.env` in this directory (`cp .env.example .env`).
# PostgreSQL: `docker compose up -d postgres` from the idp-backstage repo root.

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=backstage
POSTGRES_PASSWORD=backstage

# These are DATABASE credentials — not the Backstage web UI login.

# Optional: catalog / integrations (clone, imports)
# GITHUB_TOKEN=

# Optional: GitHub OAuth for real user sign-in (after enabling the provider in app-config.yaml — see `make auth-info` in repo root Makefile)
# AUTH_GITHUB_CLIENT_ID=
# AUTH_GITHUB_CLIENT_SECRET=

# Path to the Quarkus Gold Template for catalog import
CATALOG_TEMPLATE_PATH=
